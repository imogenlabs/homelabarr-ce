# HomelabARR CE Environment Configuration
# Copy this file to .env and fill in your values.
# The quick-start install sets these automatically — only edit if you need to change them.

# ─── Secrets ────────────────────────────────────────────────────────────────
# Use scripts/init-secrets.sh to bootstrap (recommended)
# Or set env vars directly for legacy/dev-only use:
# JWT_SECRET=
# DEFAULT_ADMIN_PASSWORD=
# ALERT_WEBHOOK_SECRET=
# SQLCIPHER_KEY=
# AUDIT_ANCHOR_KEY=   # optional — signs the out-of-band audit chain-tip anchor.
                      # Defaults to JWT_SECRET if unset; set a dedicated key to
                      # keep it independent of JWT key rotation.

# ─── Non-secret configuration ───────────────────────────────────────────────

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=14d
AUDIT_STRICT=0
ALERT_WEBHOOK_URL=
LOG_LEVEL=info

# The GID of the docker group on your host. Find it with: getent group docker | cut -d: -f3
DOCKER_GID=999

# The URL you open the dashboard at — must match exactly or login won't work.
# Example: http://192.168.1.100:8084
CORS_ORIGIN=http://your-server-ip:8084

# Where the app template library lives on your host.
# If you cloned to /opt/homelabarr (recommended), leave this as-is.
CLI_BRIDGE_HOST_PATH=/opt/homelabarr

# ─── Optional ─────────────────────────────────────────────────────────────────

# Your timezone. Used by apps that need it.
TZ=America/New_York

# Backend API port (default: 8092)
# PORT=8092

# Authentication is ON by default. Set to "false" ONLY on local-only trusted networks.
# WARNING: AUTH_ENABLED=false disables ALL authentication — any visitor can deploy
# containers and access the Docker socket. Never disable on internet-reachable hosts.
# AUTH_ENABLED=true
